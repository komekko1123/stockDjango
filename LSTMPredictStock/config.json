{
    "data": {
        "columns": [
            "Close",
            "Open",
            "High",
            "Low"
        ],
        "sequence_length": 30,
        "train_test_split": 0.85,
        "normalise": true
    },
    "training": {
        "epochs": 1,
        "batch_size": 8
    },
    "model": {
        "loss": "mse",
        "optimizer": "adam",
        "save_dir": "saved_models",
        "layers": [
